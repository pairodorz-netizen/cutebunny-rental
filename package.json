{
  "name": "cutebunny-rental",
  "private": true,
  "scripts": {
    "dev:customer": "pnpm --filter @cutebunny/customer dev",
    "dev:admin": "pnpm --filter @cutebunny/admin dev",
    "dev:api": "pnpm --filter @cutebunny/api dev",
    "build": "pnpm -r build",
    "build:customer": "pnpm --filter @cutebunny/customer build",
    "build:admin": "pnpm --filter @cutebunny/admin build",
    "build:api": "pnpm --filter @cutebunny/api build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@9.1.0"
}
