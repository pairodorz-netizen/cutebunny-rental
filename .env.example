# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────
# Connection pooler URL (used by Prisma for most queries)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?pgbouncer=true
# Direct connection URL (used for migrations)
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ─── Authentication ─────────────────────────────────────────────────────
# Secret key for signing JWT tokens (change this in production!)
JWT_SECRET=change-me-to-a-random-64-char-string

# ─── API Server ─────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Storage (Cloudflare R2) ────────────────────────────────────────────
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=cutebunny-uploads
# R2_PUBLIC_URL=https://cdn.cutebunny.rental

# ─── Cache (Upstash Redis) ──────────────────────────────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── Customer App (Next.js) ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Admin App (Vite) ───────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ─── E2E (Playwright) ───────────────────────────────────────────────────
# BUG-504-A07: admin-side categories-parity gates (gate 7 + 8) read a
# read-capable admin bearer from `ADMIN_JWT_PROD`. When unset, those
# two gates skip gracefully and only the public A02 ↔ customer gates
# run. To run them locally, mint a token with the API's HS256 JWT
# signer (hono/jwt) using the same `JWT_SECRET` the Worker uses, for
# example:
#
#   pnpm tsx -e "import('./apps/api/src/middleware/auth').then(m => \
#     m.createToken('<admin-uuid>', '<admin-email>', 'admin')).then(console.log)"
#
# For prod CI, also add this value as a GitHub Actions repo secret
# named ADMIN_JWT_PROD (Settings → Secrets and variables → Actions).
# ADMIN_JWT_PROD=
# E2E_ADMIN_URL=https://admin-eight-rouge.vercel.app
